---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Reveal from '../components/Reveal.astro';
import SectionCode from '../components/SectionCode.astro';
import Terminal from '../components/Terminal.astro';
import AmbitiGrid from '../components/AmbitiGrid.astro';
import SideDoodle from '../components/SideDoodle.astro';
import { useTranslations } from '../i18n/utils';
import { routeMap } from '../i18n/routes';
const lang = 'it' as const;
const t = useTranslations(lang);
const crumbs = [{ name: t.nav.home, href: routeMap.home[lang] }, { name: t.nav.about }];

// Demo content for the AI section — editable. Believable AI-assisted B2G workflow.
const aiSteps = [
  { cmd: 'analizza ./pratiche-edilizie --deep', out: ['✔ 1.248 file analizzati', '✔ 3 colli di bottiglia individuati'] },
  { cmd: 'genera test modulo-protocollo', out: ['✔ 87 test generati · copertura 94%'] },
  { cmd: 'audit --sicurezza', out: ['✔ Nessuna vulnerabilità critica'] },
  { cmd: 'deploy --comune demo', out: ['✔ Rilascio completato in 12s'] },
];
---
<BaseLayout title={t.meta.about.title} description={t.meta.about.description} pageKey="about" breadcrumb={crumbs}>
  <section class="hero-band">
    <SideDoodle variant="shapes" background />
    <div class="container hero-band__content">
      <SectionCode code="B1" />
      <h1>{t.nav.about}</h1>
      <p class="lead">{t.about.lead}</p>
    </div>
  </section>

  <Section data-path-node="history">
    <SectionCode code="B2" />
    <Reveal as="h2">{t.about.historyTitle}</Reveal>
    <p>{t.about.historyBody}</p>
  </Section>

  <Section alt data-path-node="areas">
    <SectionCode code="B3" />
    <Reveal as="h2">{t.about.techTitle}</Reveal>
    <AmbitiGrid items={t.about.tech} />
  </Section>

  <Section data-path-node="ai">
    <SectionCode code="B4" />
    <div class="ai-grid">
      <div>
        <Reveal as="h2">{t.about.aiTitle}</Reveal>
        <p>{t.about.aiBody}</p>
      </div>
      <Terminal steps={aiSteps} label="Esempio di workflow di sviluppo assistito dall'AI" />
    </div>
  </Section>
</BaseLayout>

<style>
  .hero-band {
    position: relative; overflow: hidden;
    padding-block: var(--space-24);
    background:
      radial-gradient(85% 120% at 100% -20%, color-mix(in srgb, var(--brand) 10%, transparent), transparent 60%),
      radial-gradient(70% 110% at 0% 130%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 60%),
      var(--bg-alt);
  }
  .hero-band__content { position: relative; z-index: 1; }
  .lead { font-size: var(--fs-500); color: var(--text-muted); margin-top: var(--space-4); }
  .ai-grid { display: grid; gap: var(--space-8); align-items: center; }
  @media (min-width: 880px) {
    .ai-grid { grid-template-columns: 1fr 1fr; gap: var(--space-12); }
    .ai-grid :global(.term) { margin-top: 0; width: 100%; }
  }
</style>
