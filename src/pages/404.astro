---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
// Served by Apache via .htaccess (ErrorDocument 404 /404.html). Bilingual fallback.
---
<BaseLayout title="Pagina non trovata — Integra" description="La pagina cercata non esiste o è stata spostata.">
  <Section>
    <p class="code">404</p>
    <h1>Pagina non trovata</h1>
    <p class="lead">La pagina che cerchi non esiste o è stata spostata.</p>
    <p class="lead" lang="en">The page you’re looking for doesn’t exist or was moved.</p>
    <p class="actions">
      <Button href="/">Torna alla home</Button>
      <a class="link" href="/en/">English version</a>
    </p>
  </Section>
</BaseLayout>

<style>
  .code { font-family: var(--font-display); font-size: var(--fs-900); font-weight: 600; color: var(--brand); line-height: 1; }
  .lead { font-size: var(--fs-500); color: var(--text-muted); margin-top: var(--space-3); }
  .actions { display: flex; align-items: center; gap: var(--space-6); margin-top: var(--space-8); flex-wrap: wrap; }
</style>
