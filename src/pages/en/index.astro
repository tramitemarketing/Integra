---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Reveal from '../../components/Reveal.astro';
import HeroRotator from '../../components/HeroRotator.astro';
import Carousel from '../../components/Carousel.astro';
import ProductCard from '../../components/ProductCard.astro';
import Button from '../../components/Button.astro';
import CountUp from '../../components/CountUp.astro';
import ProcessStrip from '../../components/ProcessStrip.astro';
import LogoCloud from '../../components/LogoCloud.astro';
import SectionCode from '../../components/SectionCode.astro';
import { useTranslations } from '../../i18n/utils';
import { routeMap, productBase } from '../../i18n/routes';

const lang = 'en' as const;
const t = useTranslations(lang);
---
<BaseLayout title={t.meta.home.title} description={t.meta.home.description} pageKey="home">
  <section class="hero-section">
    <div class="container">
      <SectionCode code="A1" />
      <div class="hero">
        <HeroRotator pre={t.home.heroPre} words={t.home.heroRotating} post={t.home.heroPost} align="center" />
        <p class="lead">{t.home.heroLead}</p>
        <p><Button href={routeMap.contact[lang]} variant="cta">{t.cta.contact}</Button></p>
      </div>
    </div>
  </section>
  <Section tone="tint" data-path-node="products">
    <SectionCode code="A2" />
    <Reveal as="h2">{t.home.productsTitle}</Reveal>
    <div class="grid-2">
      {t.products.map((p, i) => (
        <ProductCard name={p.name} tagline={p.tagline} index={i + 1}
          href={`${productBase[lang]}/${p.slug}`} cta={t.cta.discover} />
      ))}
    </div>
  </Section>
  <Section data-path-node="cases">
    <SectionCode code="A3" />
    <Reveal as="h2">{t.home.casesTitle}</Reveal>
    <p class="lead">{t.home.casesLead}</p>
    <Carousel items={t.cases} label={t.home.casesTitle} />
  </Section>
  <Section tone="accent" data-path-node="history">
    <SectionCode code="A4" />
    <div class="history">
      <div class="history__stat">
        <CountUp value={25} />
        <span class="history__statlabel">{t.home.yearsLabel}</span>
      </div>
      <div>
        <Reveal as="h2">{t.home.historyTitle}</Reveal>
        <p>{t.home.historyBody}</p>
      </div>
    </div>
  </Section>
  <Section data-path-node="process">
    <SectionCode code="A5" />
    <Reveal as="h2">{t.home.processTitle}</Reveal>
    <ProcessStrip steps={t.home.process} />
  </Section>

  <div class="clients-strip">
    <div class="container"><SectionCode code="A6" /></div>
    <LogoCloud title={t.home.clientsTitle} />
  </div>
</BaseLayout>
<style>
  .lead { font-size: var(--fs-500); color: var(--text-muted); margin-block: var(--space-4) var(--space-6); }
  /* client logos as a slim full-width ticker bar, sitting just above the footer */
  .clients-strip { margin-top: var(--space-12); }
  .hero-section {
    position: relative;
    overflow: hidden;            /* keep the auroras + grid inside the section */
    isolation: isolate;
    padding-block: var(--space-16);
    /* base wash so the top of the page isn't flat white */
    background: radial-gradient(130% 100% at 50% -10%, var(--brand-tint) 0%, transparent 60%);
  }
  /* Structural grid that slowly pans — gives the bold colour some rigour ("authority"). */
  .hero-section::before {
    content: ""; position: absolute; inset: -2px; z-index: -1; pointer-events: none;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--brand) 14%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--brand) 14%, transparent) 1px, transparent 1px);
    background-size: 48px 48px;
    -webkit-mask-image: radial-gradient(120% 85% at 50% 0%, #000 35%, transparent 78%);
            mask-image: radial-gradient(120% 85% at 50% 0%, #000 35%, transparent 78%);
    animation: gridPan 28s linear infinite;
  }
  /* Three vivid auroras (blue / cyan / light-blue) drifting behind the content.
     Pushed to the edges + corners so the dark hero text keeps AA contrast. */
  .hero-section::after {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background:
      radial-gradient(40rem 40rem at 8% -10%, color-mix(in srgb, var(--brand) 65%, transparent), transparent 60%),
      radial-gradient(34rem 34rem at 96% -6%, color-mix(in srgb, var(--accent) 60%, transparent), transparent 60%),
      radial-gradient(32rem 32rem at 78% 116%, color-mix(in srgb, var(--brand-light) 55%, transparent), transparent 60%);
    filter: blur(50px);
    opacity: .5;
    animation: auroraDrift 22s ease-in-out infinite;
  }
  @keyframes gridPan { from { background-position: 0 0, 0 0; } to { background-position: 48px 48px, 48px 48px; } }
  @keyframes auroraDrift {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    33%      { transform: translate3d(2.5rem, 1.5rem, 0) scale(1.08); }
    66%      { transform: translate3d(-2rem, 2.5rem, 0) scale(1.05); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-section::before, .hero-section::after { animation: none; }
  }
  .hero { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .hero .lead { max-width: 48ch; font-size: var(--fs-500); margin-block: var(--space-6) var(--space-8); }
  @media (max-width: 640px) { .hero-section { padding-block: var(--space-8) var(--space-12); } }
  .grid-2 { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); margin-top: var(--space-8); }
  .history { display: grid; gap: var(--space-8); align-items: center; }
  @media (min-width: 760px) { .history { grid-template-columns: auto 1fr; gap: var(--space-16); } }
  .history__stat { display: flex; flex-direction: column; }
  .history__statlabel { color: var(--text-muted); font-size: var(--fs-400); margin-top: var(--space-2); max-width: 8ch; }
</style>
