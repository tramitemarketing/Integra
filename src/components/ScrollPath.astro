---
// src/components/ScrollPath.astro
// A vertical "path" in the left margin that fills with brand colour as the page
// scrolls, with a node (icon) for each section marked `data-path-node="<key>"`.
// Nodes light up when the scroll progress reaches them. Desktop only.
---
<div class="scrollpath" aria-hidden="true">
  <span class="scrollpath__track"></span>
  <span class="scrollpath__fill"></span>
  <div class="scrollpath__nodes"></div>
</div>

<style>
  .scrollpath {
    position: fixed; left: clamp(1.25rem, calc((100vw - 72rem) / 2 - 1.6rem), 4rem);
    top: 96px; bottom: 72px; width: 2px; z-index: 5; pointer-events: none;
  }
  .scrollpath__track { position: absolute; inset: 0; background: var(--border); border-radius: 2px; }
  .scrollpath__fill {
    position: absolute; top: 0; left: 0; width: 100%; height: 0;
    background: var(--brand); border-radius: 2px; z-index: 1;
  }
  .scrollpath__node {
    position: absolute; left: 50%; transform: translate(-50%, -50%); z-index: 2;
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--bg); border: 1.5px solid var(--border);
    display: grid; place-items: center; color: var(--text-muted);
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }
  .scrollpath__node.is-active { background: var(--brand); border-color: var(--brand); color: #fff; }
  .scrollpath__node :global(svg) { width: 14px; height: 14px; }
  @media (max-width: 1180px) { .scrollpath { display: none; } }
</style>

<script>
  const svg = (inner: string) =>
    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;
  const ICONS: Record<string, string> = {
    products: svg('<path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>'),
    cases: svg('<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>'),
    history: svg('<circle cx="12" cy="8" r="6"/><path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"/>'),
    process: svg('<rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/>'),
  };
  const fallback = svg('<circle cx="12" cy="12" r="3"/>');

  const root = document.querySelector<HTMLElement>('.scrollpath');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-path-node]'));
  if (root && sections.length) {
    const fill = root.querySelector<HTMLElement>('.scrollpath__fill')!;
    const nodesWrap = root.querySelector<HTMLElement>('.scrollpath__nodes')!;

    const nodes = sections.map((el) => {
      const key = el.dataset.pathNode || '';
      const dot = document.createElement('span');
      dot.className = 'scrollpath__node';
      dot.innerHTML = ICONS[key] ?? fallback;
      nodesWrap.appendChild(dot);
      return { el, dot, progress: 0 };
    });

    const scrollMax = () => document.documentElement.scrollHeight - window.innerHeight;

    const layout = () => {
      const max = scrollMax();
      nodes.forEach((n) => {
        const absTop = n.el.getBoundingClientRect().top + window.scrollY;
        const p = max > 0 ? (absTop - window.innerHeight * 0.3) / max : 0;
        n.progress = Math.min(1, Math.max(0, p));
        n.dot.style.top = n.progress * 100 + '%';
      });
    };

    let ticking = false;
    const update = () => {
      const max = scrollMax();
      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      fill.style.height = p * 100 + '%';
      nodes.forEach((n) => n.dot.classList.toggle('is-active', p >= n.progress - 0.001));
      ticking = false;
    };

    layout(); update();
    window.addEventListener('scroll', () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
    window.addEventListener('resize', () => { layout(); update(); });
    window.addEventListener('load', () => { layout(); update(); });
  }
</script>
