---
// src/components/LogoCloud.astro
// "Ci hanno scelto" client logo strip. Placeholder boxes for now — replace each
// with a real <img src="/clients/<name>.svg" alt="<name>" /> when logos arrive.
interface Props { title: string; count?: number }
const { title, count = 6 } = Astro.props;
const landmark = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>`;
---
<div class="logos">
  <p class="logos__title">{title}</p>
  <ul class="logos__row">
    {Array.from({ length: count }).map(() => (
      <li class="logos__item">
        <span class="logos__icon" aria-hidden="true" set:html={landmark}></span>
        <span class="logos__txt">[logo]</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .logos__title {
    text-align: center; color: var(--text-muted);
    font-size: var(--fs-300); letter-spacing: 0.08em; text-transform: uppercase;
  }
  .logos__row {
    list-style: none; padding: 0; margin: var(--space-8) 0 0;
    display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
    gap: var(--space-6) var(--space-8);
  }
  .logos__item {
    display: inline-flex; align-items: center; gap: var(--space-3);
    width: 150px; height: 60px; justify-content: center;
    border: 1px dashed var(--border); border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: border-color var(--transition), color var(--transition);
  }
  .logos__item:hover { border-color: var(--brand-light); color: var(--brand); }
  .logos__icon :global(svg) { width: 22px; height: 22px; display: block; }
  .logos__txt { font-size: var(--fs-300); }
</style>
