---
// src/components/AmbitiGrid.astro
// "Ambiti" as a bento that fills two rows: a mix of rectangles (wide) and squares,
// each card with an icon badge, title, short description and a large faint icon
// watermark behind the text. Icon is chosen by `icon` key (reorder-safe). Spans map
// by position (layout assumes 5 items).
interface Ambito { name: string; desc: string; icon: string }
interface Props { items: Ambito[] }
const { items } = Astro.props;

const svg = (inner: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;

const icons: Record<string, string> = {
  video: svg('<path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2"/>'),
  shield: svg('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>'),
  cpu: svg('<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9"/><path d="M15 2v2M9 2v2M15 20v2M9 20v2M2 15h2M2 9h2M20 15h2M20 9h2"/>'),
  cloud: svg('<path d="M17.5 19a4.5 4.5 0 0 0 0-9h-1.8A6 6 0 1 0 6 18.7"/><path d="M6 19h11.5"/>'),
  route: svg('<circle cx="6" cy="19" r="2"/><circle cx="18" cy="5" r="2"/><path d="M12 19h4.5a2.5 2.5 0 0 0 0-5h-9a2.5 2.5 0 0 1 0-5H12"/>'),
};
const fallback = svg('<circle cx="12" cy="12" r="4"/>');
const iconFor = (key: string) => icons[key] ?? fallback;
---
<ul class="ambiti">
  {items.map((a) => (
    <li class="ambito">
      <span class="ambito__wm" aria-hidden="true" set:html={iconFor(a.icon)}></span>
      <div class="ambito__head">
        <span class="ambito__icon" aria-hidden="true" set:html={iconFor(a.icon)}></span>
        <span class="ambito__name">{a.name}</span>
      </div>
      <p class="ambito__desc">{a.desc}</p>
    </li>
  ))}
</ul>

<style>
  .ambiti {
    list-style: none; padding: 0; margin-top: var(--space-8);
    display: grid; gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) { .ambiti { grid-template-columns: repeat(2, 1fr); } }
  /* bento on desktop: fills two rows — rectangles + squares */
  @media (min-width: 880px) {
    .ambiti { grid-template-columns: repeat(4, 1fr); }
    .ambito:nth-child(2) { grid-column: span 2; }  /* rectangle — centred in row 1 */
    .ambito:nth-child(4) { grid-column: span 2; }  /* rectangle */
    .ambito:nth-child(5) { grid-column: span 2; }  /* rectangle */
    /* nth-child(1) and (3) stay span 1 → squares */
  }

  .ambito {
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; gap: var(--space-4);
    padding: var(--space-6);
    background: linear-gradient(180deg, var(--bg), color-mix(in srgb, var(--bg-alt) 55%, var(--bg)));
    border: 1px solid var(--border); border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .ambito:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  /* animated gradient border on hover */
  .ambito::before {
    content: ''; position: absolute; inset: 0; z-index: 2; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--ba), transparent 0deg, var(--brand) 70deg, var(--accent) 150deg, var(--brand-light) 230deg, transparent 320deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity var(--transition); pointer-events: none;
  }
  .ambito:hover::before { opacity: 1; animation: ba-spin 2.6s linear infinite; }
  @media (prefers-reduced-motion: reduce) { .ambito:hover::before { animation: none; } }

  /* large, very faint icon watermark — fills the card, behind the text */
  .ambito__wm {
    position: absolute; right: -24px; bottom: -28px; z-index: 0;
    width: 172px; height: 172px; color: var(--brand); opacity: 0.045;
    pointer-events: none; transform-origin: bottom right;
    transition: opacity var(--transition), transform var(--transition);
  }
  .ambito:hover .ambito__wm { opacity: 0.1; transform: scale(1.06); }
  .ambito__wm :global(svg) { width: 100%; height: 100%; }

  .ambito__head, .ambito__desc { position: relative; z-index: 1; }
  .ambito__head { display: flex; flex-direction: column; gap: var(--space-3); }
  .ambito__icon {
    width: 46px; height: 46px; display: grid; place-items: center;
    background: var(--brand-tint); color: var(--brand); border-radius: var(--radius-sm);
  }
  .ambito__icon :global(svg) { width: 23px; height: 23px; }
  .ambito__name { font-weight: 600; font-size: var(--fs-500); }
  .ambito__desc { color: var(--text-muted); font-size: var(--fs-300); margin: 0; max-width: 52ch; }
</style>
