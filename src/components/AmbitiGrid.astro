---
// src/components/AmbitiGrid.astro
// "Ambiti" as a bento mosaic: one large feature tile + smaller tiles. Each card has
// an icon badge, a title separated from a short description, and a faint watermark
// of its own icon. Icons map by index to the items order; layout assumes ~5 items.
interface Ambito { name: string; desc: string }
interface Props { items: Ambito[] }
const { items } = Astro.props;

const svg = (inner: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;

const icons = [
  svg('<path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2"/>'),
  svg('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>'),
  svg('<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9"/><path d="M15 2v2M9 2v2M15 20v2M9 20v2M2 15h2M2 9h2M20 15h2M20 9h2"/>'),
  svg('<path d="M17.5 19a4.5 4.5 0 0 0 0-9h-1.8A6 6 0 1 0 6 18.7"/><path d="M6 19h11.5"/>'),
  svg('<circle cx="6" cy="19" r="2"/><circle cx="18" cy="5" r="2"/><path d="M12 19h4.5a2.5 2.5 0 0 0 0-5h-9a2.5 2.5 0 0 1 0-5H12"/>'),
];
const fallback = svg('<circle cx="12" cy="12" r="4"/>');
---
<ul class="ambiti">
  {items.map((a, i) => (
    <li class="ambito">
      <span class="ambito__wm" aria-hidden="true" set:html={icons[i] ?? fallback}></span>
      <div class="ambito__head">
        <span class="ambito__icon" aria-hidden="true" set:html={icons[i] ?? fallback}></span>
        <span class="ambito__name">{a.name}</span>
      </div>
      <p class="ambito__desc">{a.desc}</p>
    </li>
  ))}
</ul>

<style>
  .ambiti {
    list-style: none; padding: 0; margin-top: var(--space-8);
    display: grid; gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) { .ambiti { grid-template-columns: repeat(2, 1fr); } }
  /* bento: one large feature tile (2x2) + four small tiles */
  @media (min-width: 880px) {
    .ambiti { grid-template-columns: repeat(4, 1fr); grid-auto-rows: minmax(165px, 1fr); }
    .ambito:nth-child(1) { grid-column: span 2; grid-row: span 2; }
  }

  .ambito {
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; justify-content: space-between; gap: var(--space-8);
    padding: var(--space-6);
    background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .ambito:hover {
    border-color: var(--brand-light); transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(21, 22, 28, 0.06);
  }

  /* faint watermark of the icon, bottom-right */
  .ambito__wm {
    position: absolute; right: -14px; bottom: -18px; z-index: 0;
    width: 108px; height: 108px; color: var(--brand); opacity: 0.07;
    pointer-events: none;
  }
  .ambito__wm :global(svg) { width: 100%; height: 100%; }

  .ambito__head, .ambito__desc { position: relative; z-index: 1; }
  .ambito__head { display: flex; flex-direction: column; gap: var(--space-3); }
  .ambito__icon {
    width: 46px; height: 46px; display: grid; place-items: center;
    background: var(--brand-tint); color: var(--brand); border-radius: var(--radius-sm);
  }
  .ambito__icon :global(svg) { width: 23px; height: 23px; }
  .ambito__name { font-weight: 600; font-size: var(--fs-500); }
  .ambito__desc { color: var(--text-muted); font-size: var(--fs-300); margin: 0; max-width: 46ch; }

  /* the big feature tile gets bigger type + a larger watermark */
  @media (min-width: 880px) {
    .ambito:nth-child(1) .ambito__name { font-size: var(--fs-700); }
    .ambito:nth-child(1) .ambito__desc { font-size: var(--fs-400); }
    .ambito:nth-child(1) .ambito__wm { width: 180px; height: 180px; right: -20px; bottom: -24px; }
  }
</style>
