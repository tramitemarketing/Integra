---
// src/components/AmbitiGrid.astro
// Renders the "ambiti" as a grid of icon cards. Icons map by index to the items
// order (videosorveglianza, safety, sistemi tecnologici, meteo-ambiente, traffico).
interface Props { items: string[] }
const { items } = Astro.props;

const svg = (inner: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;

const icons = [
  svg('<path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2"/>'),        // video / telecontrollo
  svg('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>'),                                // safety & security
  svg('<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9"/><path d="M15 2v2M9 2v2M15 20v2M9 20v2M2 15h2M2 9h2M20 15h2M20 9h2"/>'), // sistemi tecnologici
  svg('<path d="M17.5 19a4.5 4.5 0 0 0 0-9h-1.8A6 6 0 1 0 6 18.7"/><path d="M6 19h11.5"/>'),     // meteo-ambiente (cloud)
  svg('<circle cx="6" cy="19" r="2"/><circle cx="18" cy="5" r="2"/><path d="M12 19h4.5a2.5 2.5 0 0 0 0-5h-9a2.5 2.5 0 0 1 0-5H12"/>'), // traffico e mobilità (route)
];
const fallback = svg('<circle cx="12" cy="12" r="4"/>');
---
<ul class="ambiti">
  {items.map((name, i) => (
    <li class="ambito">
      <span class="ambito__icon" aria-hidden="true" set:html={icons[i] ?? fallback}></span>
      <span class="ambito__name">{name}</span>
    </li>
  ))}
</ul>

<style>
  .ambiti {
    list-style: none; padding: 0; margin-top: var(--space-8);
    display: grid; gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  }
  .ambito {
    display: flex; align-items: center; gap: var(--space-4);
    padding: var(--space-6);
    background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
    transition: border-color var(--transition), transform var(--transition);
  }
  .ambito:hover { border-color: var(--brand-light); transform: translateY(-2px); }
  .ambito__icon {
    flex: 0 0 auto; width: 44px; height: 44px;
    display: grid; place-items: center;
    background: var(--brand-tint); color: var(--brand); border-radius: var(--radius-sm);
  }
  .ambito__icon :global(svg) { width: 22px; height: 22px; }
  .ambito__name { font-weight: 600; font-size: var(--fs-400); }
</style>
