---
// src/components/ProcessStrip.astro
// The life-cycle as numbered steps. A glowing dot runs the path, drawing the
// connector as a trail it leaves behind, pulsing (expanding/fading colour wave
// + enlargement) at each point, and dropping a blue "completed" check on arrival.
interface Step { name: string; desc: string }
interface Props { steps: Step[] }
const { steps } = Astro.props;
---
<ol class="process">
  {steps.map((s, i) => (
    <li class="process__step" style={`--i:${i}`}>
      <span class="process__num">{String(i + 1).padStart(2, '0')}</span>
      <span class="process__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.2 4.5L19 7.5" /></svg>
      </span>
      {i < steps.length - 1 && <span class="process__runner" aria-hidden="true"></span>}
      <span class="process__name">{s.name}</span>
      <p class="process__desc">{s.desc}</p>
    </li>
  ))}
</ol>

<style>
  .process {
    list-style: none; padding: 0; margin-top: var(--space-8); position: relative;
    display: grid; gap: var(--space-8); grid-template-columns: 1fr;
    --seg-dur: 0.75s;   /* time the dot spends on each segment */
  }
  .process__step { position: relative; z-index: 1; }
  .process__num {
    position: relative; z-index: 1;
    display: grid; place-items: center; width: 44px; height: 44px; border-radius: 50%;
    background: var(--brand); color: #fff;
    font-family: var(--font-display); font-weight: 600; font-size: var(--fs-400);
  }
  .process__name { display: block; font-weight: 600; margin-top: var(--space-3); }
  .process__desc { color: var(--text-muted); font-size: var(--fs-300); margin-top: var(--space-2); }
  .process__runner { display: none; }

  /* blue "completed" badge — pops in when the wave reaches the point */
  .process__check {
    position: absolute; z-index: 3; top: -2px; left: 30px;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--brand);
    display: grid; place-items: center;
    box-shadow: 0 2px 6px color-mix(in srgb, var(--brand) 40%, transparent);
    transform: scale(0); opacity: 0;   /* hidden until arrival */
  }
  .process__check svg { width: 12px; height: 12px; display: block; }
  .process__check svg path { stroke: #fff; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
  .process.is-playing .process__check {
    animation: pf-check .45s cubic-bezier(.34, 1.56, .64, 1) forwards;
    animation-delay: calc(var(--i) * var(--seg-dur) + .12s);
  }

  @media (min-width: 760px) {
    .process { grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }

    /* The path itself = the trail the dot draws. Grows left→right, then stays. */
    .process__step:not(:last-child)::after {
      content: ''; position: absolute; z-index: 0;
      top: 20px; left: 22px;
      width: calc(100% + var(--space-6)); height: 4px; border-radius: 2px;
      background: var(--grad-brand);
      box-shadow: 0 0 10px color-mix(in srgb, var(--accent-light) 50%, transparent);
      transform: scaleX(0); transform-origin: left center;
    }
    /* The travelling dot. Wrapper spans one segment; the dot (::before) rides it. */
    .process__runner {
      display: block; position: absolute; z-index: 2;
      top: 22px; left: 22px; height: 0;
      width: calc(100% + var(--space-6));
    }
    .process__runner::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 16px; height: 16px; border-radius: 50%;
      background: radial-gradient(circle at 50% 50%, #fff 0%, var(--accent-light) 70%);
      box-shadow: 0 0 14px 3px color-mix(in srgb, var(--accent-light) 70%, transparent);
      transform: translate(-50%, -50%) scale(.6);
      opacity: 0;
    }

    .process.is-playing .process__step:not(:last-child)::after {
      animation: pf-fill var(--seg-dur) ease-out forwards;
      animation-delay: calc(var(--i) * var(--seg-dur));
    }
    .process.is-playing .process__runner::before {
      animation: pf-runner var(--seg-dur) linear forwards;
      animation-delay: calc(var(--i) * var(--seg-dur));
    }
    .process.is-playing .process__num {
      animation: pf-pulse .6s ease-out forwards;
      animation-delay: calc(var(--i) * var(--seg-dur));
    }
  }

  @keyframes pf-fill { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  @keyframes pf-runner {
    0%   { left: 0;    opacity: 0; transform: translate(-50%, -50%) scale(.6); }
    12%  {             opacity: 1; transform: translate(-50%, -50%) scale(1); }
    88%  {             opacity: 1; transform: translate(-50%, -50%) scale(1); }
    100% { left: 100%; opacity: 0; transform: translate(-50%, -50%) scale(.6); }
  }

  /* arrival pulse: enlarge + an expanding colour wave that fades out */
  @keyframes pf-pulse {
    0%   { transform: scale(1);    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent-light) 70%, transparent); }
    35%  { transform: scale(1.22); }
    100% { transform: scale(1);    box-shadow: 0 0 0 22px color-mix(in srgb, var(--accent-light) 0%, transparent); }
  }

  @keyframes pf-check {
    0%   { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* No-motion: show the finished state (full path + all checks), no movement. */
  @media (prefers-reduced-motion: reduce) {
    .process__runner { display: none; }
    .process__check { transform: scale(1); opacity: 1; }
    .process__step:not(:last-child)::after { transform: scaleX(1); }
  }
</style>

<script>
  const lists = document.querySelectorAll<HTMLElement>('.process');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (lists.length && !reduce && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-playing');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '0px 0px -15% 0px' });

    lists.forEach((list) => io.observe(list));
  }
</script>
