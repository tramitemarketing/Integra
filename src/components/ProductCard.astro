---
// src/components/ProductCard.astro
// Whole card is clickable via a "stretched link" on the CTA, so the heading/tagline
// text stays un-underlined.
interface Props { name: string; tagline: string; href: string; cta: string; index?: number; }
const { name, tagline, href, cta, index } = Astro.props;
const num = index != null ? String(index).padStart(2, '0') : null;
---
<article class="pcard">
  {num && <span class="pcard__num">{num}</span>}
  <h3 class="pcard__name">{name}</h3>
  <p class="pcard__tag">{tagline}</p>
  <a href={href} class="pcard__cta">{cta} <span class="pcard__arrow" aria-hidden="true">→</span></a>
</article>
<style>
  .pcard {
    position: relative;
    display: flex; flex-direction: column; gap: var(--space-2);
    padding: var(--space-8);
    border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg);
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition);
  }
  .pcard:hover { border-color: var(--brand-light); transform: translateY(-3px); box-shadow: 0 16px 40px rgba(21, 22, 28, 0.08); }
  .pcard__num { font-family: var(--font-display); font-weight: 600; color: var(--brand); font-size: var(--fs-500); }
  .pcard__name { font-size: var(--fs-600); margin-top: var(--space-2); }
  .pcard__tag { color: var(--text-muted); }
  .pcard__cta {
    text-decoration: none; color: var(--brand); font-weight: 600; font-size: var(--fs-300);
    margin-top: var(--space-4); display: inline-flex; align-items: center; gap: .4rem;
  }
  /* stretched link — makes the whole card clickable */
  .pcard__cta::after { content: ''; position: absolute; inset: 0; }
  .pcard__arrow { transition: transform var(--transition); }
  .pcard:hover .pcard__cta { color: var(--brand-light); }
  .pcard:hover .pcard__arrow { transform: translateX(4px); }
</style>
