---
// src/components/HeroRotator.astro
// Stacked title: the black `pre`/`post` lines stay fixed; only the blue word,
// on its own fixed-height line, animates. No reflow of the surrounding text.
interface Props { pre: string; words: string[]; post: string; align?: 'start' | 'center'; }
const { pre, words, post, align = 'start' } = Astro.props;
---
<h1 class:list={["hero-title", align === 'center' && "hero-title--center"]}>
  <span class="hero-line">{pre}</span>
  <span class="hero-rotator" data-words={JSON.stringify(words)}>
    <span class="hero-rotator__word">{words[0]}</span>
  </span>
  <span class="hero-line hero-line--post">{post}</span>
</h1>

<style>
  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-title--center {
    align-items: center;
    text-align: center;
    font-size: clamp(2.75rem, 1.3rem + 6vw, 5rem);
  }
  .hero-line { display: block; }
  /* secondary tagline — smaller and quieter than the main statement */
  .hero-line--post {
    font-size: 0.4em;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0;
    margin-top: 0.35em;
  }

  /* One-shot staggered entrance on load. */
  @keyframes heroIn { from { opacity: 0; transform: translateY(0.5em); } to { opacity: 1; transform: none; } }
  .hero-title > * { opacity: 0; animation: heroIn 600ms cubic-bezier(.2, .7, .2, 1) forwards; }
  .hero-title > *:nth-child(1) { animation-delay: 80ms; }
  .hero-title > *:nth-child(2) { animation-delay: 220ms; }
  .hero-title > *:nth-child(3) { animation-delay: 360ms; }

  /* Own line, fixed height = the black lines above/below never move;
     overflow hides the word sliding in/out; nowrap keeps it one line. */
  .hero-rotator {
    display: grid;
    height: 1.1em;
    line-height: 1.1;
    overflow: hidden;
    white-space: nowrap;
  }
  .hero-rotator__word {
    grid-area: 1 / 1;
    align-self: start;
    color: var(--brand);
    transition: opacity 400ms ease, transform 400ms ease;
  }
  .hero-rotator__word.is-out { opacity: 0; transform: translateY(-0.6em); }
  .hero-rotator__word.is-in { opacity: 0; transform: translateY(0.6em); }
  @media (prefers-reduced-motion: reduce) {
    .hero-rotator__word { transition: none; }
    .hero-title > * { opacity: 1; animation: none; }
  }
</style>

<script>
  const timers: ReturnType<typeof setInterval>[] = [];

  document.addEventListener('astro:before-swap', () => {
    timers.forEach(clearInterval);
    timers.length = 0;
  });

  document.querySelectorAll<HTMLElement>('.hero-rotator').forEach((root) => {
    const words: string[] = JSON.parse(root.dataset.words || '[]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wordEl = root.querySelector('.hero-rotator__word') as HTMLElement;
    if (!reduce && words.length > 1) {
      let i = 0;
      const id = setInterval(() => {
        wordEl.classList.add('is-out');
        setTimeout(() => {
          i = (i + 1) % words.length;
          wordEl.textContent = words[i];
          wordEl.classList.remove('is-out');
          wordEl.classList.add('is-in');
          requestAnimationFrame(() => requestAnimationFrame(() => wordEl.classList.remove('is-in')));
        }, 400);
      }, 2600);
      timers.push(id);
    }
  });
</script>
